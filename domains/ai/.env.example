# PT-Edge (AI domain) — credentials
# Copy to domains/ai/.env and fill in values.
# NEVER commit this file to git.

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/pt_edge
DATABASE_URL_READONLY=
API_TOKEN=dev-token
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_FILE=
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
V2EX_TOKEN=
SEMANTIC_SCHOLAR_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=
GSC_PROPERTY=sc-domain:mcp.phasetransitions.ai
UMAMI_DATABASE_URL=
UMAMI_WEBSITE_ID=
RENDER_API_KEY=
RENDER_DEPLOY_HOOK_URL=
LLM_BUDGET_MULTIPLIER=5.0
